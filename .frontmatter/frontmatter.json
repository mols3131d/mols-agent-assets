{
  "$schema": "https://beta.frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": false,
      "previewPath": null,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        },
        {
          "title": "Content preview",
          "name": "preview",
          "type": "image"
        },
        {
          "title": "Is in draft",
          "name": "draft",
          "type": "draft"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "Categories",
          "name": "categories",
          "type": "categories"
        },
        {
          "title": "ID",
          "name": "id",
          "type": "string"
        },
        {
          "title": "Last Modified",
          "name": "lastmod",
          "type": "datetime",
          "default": "{{now}}"
        },
        {
          "title": "Author",
          "name": "author",
          "type": "string"
        },
        {
          "title": "Agent Readable",
          "name": "agent-readable",
          "type": "boolean",
          "default": true
        },
        {
          "title": "Agent Editable",
          "name": "agent-editable",
          "type": "boolean",
          "default": true
        },
        {
          "title": "Agent Moveable",
          "name": "agent-moveable",
          "type": "boolean",
          "default": false
        },
        {
          "title": "Agent Deletable",
          "name": "agent-deletable",
          "type": "boolean",
          "default": false
        },
        {
          "title": "Agent Friendly",
          "name": "agent-friendly",
          "type": "boolean",
          "default": false
        },
        {
          "title": "ADR Status",
          "name": "adr-status",
          "type": "string"
        },
        {
          "title": "ADR Keyword",
          "name": "adr-keyword",
          "type": "string"
        }
      ]
    }
  ],
  "frontMatter.framework.id": "other",
  "frontMatter.content.publicFolder": "",
  "frontMatter.content.pageFolders": [
    {
      "title": "docs",
      "path": "[[workspace]]/docs"
    }
  ],
  "frontMatter.extends": [
    "./.frontmatter/frontmatter.json"
  ]
}