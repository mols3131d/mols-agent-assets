{
	"$schema": "https://beta.frontmatter.codes/frontmatter.schema.json",
	"frontMatter.taxonomy.contentTypeField": "fmContentType",
	"frontMatter.content.pageFolders": [
		{
			"title": "ADR",
			"path": "[[workspace]]/docs/adr",
			"contentTypes": [
				"adr"
			]
		},
		{
			"title": "SPEC",
			"path": "[[workspace]]/docs/spec",
			"contentTypes": [
				"spec"
			]
		},
		{
			"title": "Kanban",
			"path": "[[workspace]]/docs/kanban",
			"contentTypes": [
				"kanban"
			]
		},
		{
			"title": "Agent Rule",
			"path": "[[workspace]]/.agents/rules",
			"contentTypes": [
				"agent-rule"
			]
		},
		{
			"title": "Agent Skill",
			"path": "[[workspace]]/.agents/skills",
			"contentTypes": [
				"agent-skill"
			]
		}
	],
	"frontMatter.taxonomy.contentTypes": [
		{
			"name": "default",
			"pageBundle": false,
			"template": "[[workspace]]/.frontmatter/templates/default.md",
			"fields": [
				{
					"title": "ID",
					"name": "id",
					"type": "string"
				},
				{
					"title": "Title",
					"name": "title",
					"type": "string"
				},
				{
					"title": "Description",
					"name": "description",
					"type": "string"
				},
				{
					"title": "Categories",
					"name": "categories",
					"type": "categories",
					"description": "콘텐츠의 논리적 분류 및 유형 정의 (Managed in `.frontmatter/database/taxonomyDb.json`)"
				},
				{
					"title": "Tags",
					"name": "tags",
					"type": "tags",
					"description": "문서 검색 및 필터링을 위한 키워드 데이터 (Managed in `.frontmatter/database/taxonomyDb.json`)"
				},
				{
					"title": "Create Date",
					"name": "date",
					"type": "datetime",
					"default": "{{now}}",
					"isPublishDate": true
				},
				{
					"title": "Update Date",
					"name": "lastmod",
					"type": "datetime",
					"default": "{{now}}",
					"description": "문서 수정 날짜. 잔수정으로 갱신하지 않음."
				}
			]
		},
		{
			"name": "adr",
			"pageBundle": false,
			"template": "[[workspace]]/adr/TEMPLATE.md",
			"fields": [
				{
					"title": "ID",
					"name": "id",
					"type": "string"
				},
				{
					"title": "Title",
					"name": "title",
					"type": "string"
				},
				{
					"title": "Description",
					"name": "description",
					"type": "string"
				},
				{
					"title": "Status",
					"name": "status",
					"type": "choice",
					"choices": [
						"proposed",
						"accepted",
						"deprecated",
						"superseded",
						"rejected"
					]
				},
				{
					"title": "Categories",
					"name": "categories",
					"type": "categories"
				},
				{
					"title": "Tags",
					"name": "tags",
					"type": "tags"
				},
				{
					"title": "Related Files",
					"name": "related-files",
					"type": "list"
				}
			]
		},
		{
			"name": "spec",
			"pageBundle": false,
			"template": "[[workspace]]/spec/TEMPLATE.md",
			"fields": [
				{
					"title": "ID",
					"name": "id",
					"type": "string"
				},
				{
					"title": "Title",
					"name": "title",
					"type": "string"
				},
				{
					"title": "Description",
					"name": "description",
					"type": "string"
				},
				{
					"title": "Status",
					"name": "status",
					"type": "choice",
					"choices": [
						"draft",
						"approved",
						"stable",
						"archived"
					]
				},
				{
					"title": "Categories",
					"name": "categories",
					"type": "categories"
				},
				{
					"title": "Tags",
					"name": "tags",
					"type": "tags"
				}
			]
		},
		{
			"name": "kanban",
			"pageBundle": false,
			"template": "[[workspace]]/.frontmatter/templates/kanban.md",
			"fields": [
				{
					"title": "ID",
					"name": "id",
					"type": "string"
				},
				{
					"title": "Status",
					"name": "status",
					"type": "choice",
					"choices": [
						"backlog",
						"todo",
						"in-progress",
						"review",
						"done"
					],
					"default": "backlog"
				},
				{
					"title": "Priority",
					"name": "priority",
					"type": "choice",
					"choices": [
						"critical",
						"high",
						"medium",
						"low"
					],
					"default": "medium"
				},
				{
					"title": "Assignee",
					"name": "assignee",
					"type": "string"
				},
				{
					"title": "Labels",
					"name": "labels",
					"type": "tags"
				},
				{
					"title": "Create Date",
					"name": "created",
					"type": "datetime",
					"default": "{{now}}",
					"isPublishDate": true
				},
				{
					"title": "Update Date",
					"name": "modified",
					"type": "datetime",
					"default": "{{now}}",
					"isModifiedDate": true
				},
				{
					"title": "Due Date",
					"name": "dueDate",
					"type": "datetime"
				},
				{
					"title": "Completed At",
					"name": "completedAt",
					"type": "datetime"
				},
				{
					"title": "Order",
					"name": "order",
					"type": "string",
					"default": "a0"
				}
			]
		},
		{
			"name": "agent-rule",
			"pageBundle": false,
			"template": "[[workspace]]/.frontmatter/templates/agent-rule.md",
			"fields": [
				{
					"title": "Name",
					"name": "name",
					"type": "string"
				},
				{
					"title": "Trigger",
					"name": "trigger",
					"type": "choice",
					"choices": [
						"manual",
						"always_on",
						"model_decision",
						"glob"
					],
					"required": true
				},
				{
					"title": "Description",
					"name": "description",
					"type": "string"
				},
				{
					"title": "Categories",
					"name": "categories",
					"type": "categories"
				},
				{
					"title": "Tags",
					"name": "tags",
					"type": "tags"
				},
				{
					"title": "Glob",
					"name": "glob",
					"type": "list",
					"when": {
						"fieldRef": "trigger",
						"operator": "eq",
						"value": "glob"
					}
				},
				{
					"title": "Version",
					"name": "version",
					"type": "string",
					"default": "0.0.0"
				}
			]
		},
		{
			"name": "agent-skill",
			"pageBundle": false,
			"template": "[[workspace]]/.frontmatter/templates/agent-skill.md",
			"fields": [
				{
					"title": "Name",
					"name": "name",
					"type": "string"
				},
				{
					"title": "Description",
					"name": "description",
					"type": "string"
				},
				{
					"title": "Categories",
					"name": "categories",
					"type": "categories"
				},
				{
					"title": "Tags",
					"name": "tags",
					"type": "tags"
				},
				{
					"title": "Version",
					"name": "version",
					"type": "string",
					"default": "0.0.0"
				}
			]
		}
	],
	"frontMatter.framework.id": "other",
	"frontMatter.content.publicFolder": "",
	"frontMatter.media.supportedMimeTypes": [
		"image/*",
		"video/*",
		"audio/*"
	]
}